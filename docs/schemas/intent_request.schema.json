{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "intent_request.schema.json",
  "title": "ActionRequest",
  "description": "Intent Bridge output: a strictly-typed action request that Box can execute or reject. Content-independent — no D&D-specific vocabulary in field names.",
  "type": "object",
  "required": ["intent_type", "actor_id", "provenance", "status"],
  "properties": {
    "intent_type": {
      "type": "string",
      "description": "Action type from the intent taxonomy (§1 of INTENT_BRIDGE.md)",
      "enum": [
        "attack",
        "cast_spell",
        "move",
        "use_ability",
        "end_turn",
        "buy",
        "rest",
        "grapple",
        "disarm",
        "sunder",
        "trip",
        "bull_rush",
        "overrun",
        "charge",
        "full_attack",
        "withdraw",
        "total_defense",
        "fight_defensively",
        "aid_another",
        "ready_action",
        "delay",
        "interact_object",
        "talk_to",
        "ask_rules",
        "ask_recap",
        "retract",
        "undo_request"
      ]
    },
    "actor_id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable entity ID of the entity performing the action"
    },
    "targets": {
      "type": "array",
      "description": "0..N typed target selectors",
      "items": { "$ref": "#/$defs/Target" },
      "maxItems": 20
    },
    "instrument": {
      "$ref": "#/$defs/Instrument",
      "description": "Weapon, spell, ability, or item used"
    },
    "parameters": {
      "type": "object",
      "description": "Action-specific key-value pairs (destination, quantity, trigger, etc.)",
      "additionalProperties": true
    },
    "constraints": {
      "$ref": "#/$defs/Constraint",
      "description": "Informational validation flags (not enforced by bridge)"
    },
    "provenance": {
      "$ref": "#/$defs/Provenance",
      "description": "Audit trail for the action request"
    },
    "status": {
      "type": "string",
      "enum": ["ok", "needs_clarification", "unknown", "reject"],
      "description": "Resolution status of this request"
    },
    "clarify": {
      "$ref": "#/$defs/Clarify",
      "description": "Clarification payload (required when status is needs_clarification)"
    },
    "reject_reason": {
      "type": "string",
      "description": "Reason for rejection (required when status is reject)",
      "examples": [
        "target_not_found",
        "spell_not_found",
        "actor_not_found",
        "not_yet_supported",
        "parse_failure",
        "empty_input"
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "needs_clarification" } }
      },
      "then": {
        "required": ["clarify"]
      }
    },
    {
      "if": {
        "properties": { "status": { "const": "reject" } }
      },
      "then": {
        "required": ["reject_reason"]
      }
    }
  ],
  "$defs": {
    "Target": {
      "type": "object",
      "required": ["selector_type"],
      "properties": {
        "entity_id": {
          "type": "string",
          "description": "Resolved entity ID (required when selector_type is 'entity')"
        },
        "entity_ref": {
          "type": "string",
          "description": "Original player text reference (for audit trail)"
        },
        "position": {
          "$ref": "#/$defs/Position",
          "description": "Grid position (required when selector_type is 'position' or 'area')"
        },
        "selector_type": {
          "type": "string",
          "enum": ["entity", "position", "area", "self", "none"],
          "description": "Type of target selection"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "selector_type": { "const": "entity" } }
          },
          "then": {
            "required": ["entity_id"]
          }
        },
        {
          "if": {
            "properties": { "selector_type": { "enum": ["position", "area"] } }
          },
          "then": {
            "required": ["position"]
          }
        }
      ]
    },
    "Position": {
      "type": "object",
      "required": ["x", "y"],
      "properties": {
        "x": {
          "type": "integer",
          "description": "Grid x-coordinate"
        },
        "y": {
          "type": "integer",
          "description": "Grid y-coordinate"
        },
        "z": {
          "type": "integer",
          "description": "Grid z-coordinate (optional, for 3D positioning)",
          "default": 0
        }
      },
      "additionalProperties": false
    },
    "Instrument": {
      "type": "object",
      "required": ["instrument_type"],
      "properties": {
        "instrument_type": {
          "type": "string",
          "enum": ["weapon", "spell", "ability", "item", "unarmed", "none"],
          "description": "Category of instrument"
        },
        "ref": {
          "type": "string",
          "description": "Stable ID (weapon_id, spell_id, ability_id, item_id)"
        },
        "display_name": {
          "type": "string",
          "description": "Human-readable name (for audit, not for resolution)"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "instrument_type": { "enum": ["weapon", "spell", "ability", "item"] } }
          },
          "then": {
            "required": ["ref"]
          }
        }
      ]
    },
    "Constraint": {
      "type": "object",
      "properties": {
        "requires_confirm": {
          "type": "boolean",
          "description": "True for AoE placement, destructive actions",
          "default": false
        },
        "requires_los": {
          "type": "boolean",
          "description": "True if line-of-sight is needed (informational only)",
          "default": false
        },
        "max_range": {
          "type": "integer",
          "description": "Range limit in feet (informational only, not enforced by bridge)",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "Provenance": {
      "type": "object",
      "required": ["stt_text", "conversation_turn_id"],
      "properties": {
        "stt_text": {
          "type": "string",
          "description": "Original STT transcript text"
        },
        "stt_confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "STT engine confidence score"
        },
        "conversation_turn_id": {
          "type": "string",
          "description": "Unique identifier for this conversation turn"
        },
        "context_refs": {
          "type": "array",
          "items": { "type": "string" },
          "description": "STM context references used in resolution (e.g., 'stm:last_target')"
        },
        "parse_confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "Voice intent parser confidence score"
        }
      },
      "additionalProperties": false
    },
    "Clarify": {
      "type": "object",
      "required": ["question", "options", "clarify_type", "missing_fields"],
      "properties": {
        "question": {
          "type": "string",
          "description": "DM-persona clarification question (no coaching, no mechanical info)"
        },
        "options": {
          "type": "array",
          "items": { "$ref": "#/$defs/Option" },
          "minItems": 2,
          "maxItems": 6,
          "description": "Bounded choices for the player"
        },
        "clarify_type": {
          "type": "string",
          "enum": ["target", "location", "instrument", "action", "spell", "direction"],
          "description": "Category of clarification needed"
        },
        "missing_fields": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Which ActionRequest fields are incomplete"
        }
      },
      "additionalProperties": false
    },
    "Option": {
      "type": "object",
      "required": ["label"],
      "properties": {
        "label": {
          "type": "string",
          "description": "Display text for this option (e.g., 'Goblin Warrior (near the brazier)')"
        },
        "entity_id": {
          "type": "string",
          "description": "Resolved entity ID if applicable"
        },
        "position": {
          "$ref": "#/$defs/Position",
          "description": "Position if applicable"
        }
      },
      "additionalProperties": false
    }
  }
}
